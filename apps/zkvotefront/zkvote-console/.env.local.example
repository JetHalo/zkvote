NEXT_PUBLIC_APP_NAME=zkVote
NEXT_PUBLIC_DEFAULT_LANGUAGE=en
NEXT_PUBLIC_CHAIN_NAME=Horizen Testnet
NEXT_PUBLIC_CHAIN_ID=2651420
NEXT_PUBLIC_RPC_URL=https://horizen-testnet.rpc.caldera.xyz/http
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=
NEXT_PUBLIC_PROPOSAL_REGISTRY_ADDRESS=
NEXT_PUBLIC_IPFS_GATEWAY_URL=https://ipfs.io/ipfs
NEXT_PUBLIC_ENABLE_DEV_MOCKS=false

# Server-only
# Required for durable app state: memberships, proofs, votes, proposal metadata URIs.
DATABASE_URL=postgresql://YOUR_DB_USER@localhost:5432/zkvote

# Required for chain state recovery after restart: minted passes and proposals from chain.
# Example final value shape:
# GOLDSKY_SUBGRAPH_URL=https://api.goldsky.com/api/public/<project>/subgraphs/zkvote-horizen-testnet/1.0.0/gn
GOLDSKY_SUBGRAPH_URL=
GOLDSKY_API_KEY=

# Optional if you use Goldsky Edge RPC for indexing or backend chain reads.
# Example: https://edge.goldsky.com/standard/evm/2651420?secret=YOUR_SECRET
GOLDSKY_RPC_URL=

# For local end-to-end IPFS testing, you can run:
# npm run ipfs:mock --workspace zkvote-console
# Then set:
# NEXT_PUBLIC_IPFS_GATEWAY_URL=http://127.0.0.1:8787/ipfs
# IPFS_API_URL=http://127.0.0.1:8787/pin
IPFS_API_URL=
IPFS_API_KEY=
IPFS_API_AUTH_HEADER=Authorization
ZKVERIFY_RPC_URL=
ZKVERIFY_WS_URL=
ZKVERIFY_NETWORK=Volta
ZKVERIFY_MNEMONIC=
