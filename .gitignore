**/*.test.tsx
**/*.test.js
**/*.test.jsx
**/*.spec.ts
**/*.spec.tsx
**/*.spec.js
**/*.spec.jsx

# Ignore generated build artifacts.
contracts/cache/
contracts/out/
subgraphs/**/build/
subgraphs/**/generated/
